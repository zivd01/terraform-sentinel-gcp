# --- Central Configuration for TFE/GCP Setup Scripts ---
# Fill out these variables before running any setup scripts.

# The ID of your Google Cloud Project
GCP_PROJECT_ID="your-gcp-project-id"

# The name of the Service Account to be created (or used) by the setup scripts
GCP_SA_NAME="tfe-dynamic-sa"

# Your Terraform Cloud / Enterprise Organization name
TFE_ORG_NAME="your-tfe-organization-name"

# The human-readable name of your Terraform Workspace (used for WIF binding security)
TFE_WORKSPACE_NAME="your-tfe-workspace-name"

# The unique identifier of your Terraform Workspace (e.g. ws-1234abcd5678efgh) 
# Used by the deploy_policy_set.sh script to attach Sentinel rules via the API.
# You can find this in Terraform Cloud under Workspace Settings -> General.
TFE_WORKSPACE_ID="ws-1234abcd5678"

# --- Advanced Configuration (Optional but recommended for uniqueness) ---

# The name of the Workload Identity Pool (must be unique per GCP project)
GCP_WIF_POOL_NAME="tfe-identity-pool"

# The name of the Workload Identity Provider
GCP_WIF_PROVIDER_NAME="tfe-oidc-provider"

# The name of the Policy Set that will be created in Terraform Cloud
TFE_POLICY_SET_NAME="gcp-governance-policies"
